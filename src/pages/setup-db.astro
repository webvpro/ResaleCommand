---
import {
  Client,
  Databases,
  Storage,
  Permission,
  Role,
  ID,
} from "node-appwrite";

const logs: string[] = [];
function log(msg: string) {
  logs.push(`[${new Date().toLocaleTimeString()}] ${msg}`);
  console.log(msg);
}

// Config
const ENDPOINT = import.meta.env.PUBLIC_APPWRITE_ENDPOINT;
const PROJECT_ID = import.meta.env.PUBLIC_APPWRITE_PROJECT_ID;
const API_KEY =
  import.meta.env.APPWRITE_API_KEY || process.env.APPWRITE_API_KEY;

const DB_ID = import.meta.env.PUBLIC_APPWRITE_DB_ID || "resale_db";
const ITEMS_COL = import.meta.env.PUBLIC_APPWRITE_COLLECTION_ID || "items";
const CARTS_COL = "carts";
const EXPENSES_COL = "expenses";
const API_KEYS_COL = "api_keys";
const BUCKET_ID = import.meta.env.PUBLIC_APPWRITE_BUCKET_ID || "item_images";

let success = false;

if (!API_KEY) {
  log("ERROR: APPWRITE_API_KEY not found in environment variables.");
} else {
  try {
    const client = new Client()
      .setEndpoint(ENDPOINT)
      .setProject(PROJECT_ID)
      .setKey(API_KEY);

    const db = new Databases(client);
    const storage = new Storage(client);

    log(`Connecting to Appwrite Project: ${PROJECT_ID}`);
    log(`Target Database: ${DB_ID}`);

    // 1. Ensure Database Exists
    try {
      await db.get(DB_ID);
      log("Database exists.");
    } catch (e) {
      log("Database missing. Creating...");
      await db.create(DB_ID, "Resale DB");
      log(`Database ${DB_ID} created.`);
    }

    // 2. Clear Collections (Carts, Expenses, Items, API Keys)
    const collections = [CARTS_COL, EXPENSES_COL, ITEMS_COL, API_KEYS_COL];
    for (const colId of collections) {
      try {
        await db.deleteCollection(DB_ID, colId);
        log(`Deleted existing collection: ${colId}`);
        // Wait to avoid race conditions
        await new Promise((r) => setTimeout(r, 1000));
      } catch (e) {
        log(
          `Collection ${colId} did not exist (or could not delete). Continuing.`,
        );
      }
    }

    // 3. Create Carts Collection
    log(`Creating Collection: ${CARTS_COL}...`);
    await db.createCollection(
      DB_ID,
      CARTS_COL,
      "Carts",
      [
        Permission.read(Role.any()),
        Permission.create(Role.users()),
        Permission.update(Role.users()),
        Permission.delete(Role.users()),
      ],
      true,
    );

    // Attributes for Carts
    await db.createStringAttribute(DB_ID, CARTS_COL, "source", 255, true);
    await db.createStringAttribute(DB_ID, CARTS_COL, "tenantId", 255, true);
    await db.createStringAttribute(DB_ID, CARTS_COL, "buyerId", 255, true);
    await db.createStringAttribute(
      DB_ID,
      CARTS_COL,
      "status",
      50,
      false,
      "active",
    );
    await db.createIntegerAttribute(DB_ID, CARTS_COL, "itemCount", false, 0); // min/max undefined, default 0
    await db.createFloatAttribute(DB_ID, CARTS_COL, "totalCost", false, 0.0);
    await db.createFloatAttribute(
      DB_ID,
      CARTS_COL,
      "projectedRevenue",
      false,
      0.0,
    );
    await db.createFloatAttribute(
      DB_ID,
      CARTS_COL,
      "potentialProfit",
      false,
      0.0,
    );
    await db.createDatetimeAttribute(DB_ID, CARTS_COL, "date", false);
    await db.createDatetimeAttribute(DB_ID, CARTS_COL, "completedAt", false);
    await db.createDatetimeAttribute(DB_ID, CARTS_COL, "processedAt", false);
    log(`Carts Schema Created.`);

    // 4. Create Expenses Collection
    log(`Creating Collection: ${EXPENSES_COL}...`);
    await db.createCollection(
      DB_ID,
      EXPENSES_COL,
      "Expenses",
      [
        Permission.read(Role.any()), // Allow read for now
        Permission.create(Role.users()),
        Permission.update(Role.users()),
        Permission.delete(Role.users()),
      ],
      true,
    );

    // Attributes for Expenses
    await db.createStringAttribute(DB_ID, EXPENSES_COL, "cartId", 255, true);
    await db.createStringAttribute(DB_ID, EXPENSES_COL, "tenantId", 255, true);
    await db.createFloatAttribute(DB_ID, EXPENSES_COL, "amount", true);
    await db.createStringAttribute(DB_ID, EXPENSES_COL, "note", 1000, false);
    await db.createStringAttribute(
      DB_ID,
      EXPENSES_COL,
      "receiptImageId",
      255,
      false,
    );
    await db.createDatetimeAttribute(DB_ID, EXPENSES_COL, "date", true);
    log(`Expenses Schema Created.`);

    // 5. Create Items Collection
    log(`Creating Collection: ${ITEMS_COL}...`);
    await db.createCollection(
      DB_ID,
      ITEMS_COL,
      "Resale Items",
      [
        Permission.read(Role.any()),
        Permission.create(Role.users()),
        Permission.update(Role.users()),
        Permission.delete(Role.users()),
      ],
      true,
    );

    // Attributes for Items
    // identity, title, keywords(arr), conditionNotes, redFlags(arr), paidPrice, resalePrice, maxBuyPrice, purchaseLocation, binLocation, status, cartId, tenantId
    await db.createStringAttribute(DB_ID, ITEMS_COL, "identity", 255, false);
    await db.createStringAttribute(DB_ID, ITEMS_COL, "title", 255, false);
    await db.createStringAttribute(
      DB_ID,
      ITEMS_COL,
      "keywords",
      255,
      false,
      undefined,
      true,
    ); // Array
    await db.createStringAttribute(
      DB_ID,
      ITEMS_COL,
      "conditionNotes",
      5000,
      false,
    );
    await db.createStringAttribute(
      DB_ID,
      ITEMS_COL,
      "redFlags",
      255,
      false,
      undefined,
      true,
    ); // Array
    await db.createFloatAttribute(DB_ID, ITEMS_COL, "paidPrice", false, 0.0);
    await db.createFloatAttribute(DB_ID, ITEMS_COL, "resalePrice", false, 0.0);
    await db.createFloatAttribute(DB_ID, ITEMS_COL, "maxBuyPrice", false, 0.0);
    await db.createStringAttribute(
      DB_ID,
      ITEMS_COL,
      "purchaseLocation",
      255,
      false,
    );
    await db.createStringAttribute(DB_ID, ITEMS_COL, "binLocation", 255, false);
    await db.createStringAttribute(
      DB_ID,
      ITEMS_COL,
      "status",
      50,
      false,
      "scouted",
    );
    await db.createStringAttribute(DB_ID, ITEMS_COL, "cartId", 255, false);
    await db.createStringAttribute(DB_ID, ITEMS_COL, "tenantId", 255, true);
    await db.createStringAttribute(DB_ID, ITEMS_COL, "imageId", 255, false);
    log(`Items Schema Created.`);

    // 6. Create API Keys Collection
    log(`Creating Collection: ${API_KEYS_COL}...`);
    await db.createCollection(
      DB_ID,
      API_KEYS_COL,
      "API Keys",
      [
        Permission.read(Role.any()), // Server needs to read keys by value
        Permission.create(Role.users()),
        Permission.update(Role.users()),
        Permission.delete(Role.users()),
      ],
      true,
    );
    await db.createStringAttribute(DB_ID, API_KEYS_COL, "key", 255, true);
    await db.createStringAttribute(DB_ID, API_KEYS_COL, "name", 255, true);
    await db.createStringAttribute(DB_ID, API_KEYS_COL, "userId", 255, true);
    await db.createStringAttribute(DB_ID, API_KEYS_COL, "tenantId", 255, true);
    await db.createBooleanAttribute(
      DB_ID,
      API_KEYS_COL,
      "isActive",
      false,
      true,
    );
    log(`API Keys Schema Created.`);

    // 7. Ensure Storage Bucket Exists
    try {
      await storage.getBucket(BUCKET_ID);
      log(`Bucket ${BUCKET_ID} exists.`);
    } catch (e) {
      log(`Bucket missing. Creating ${BUCKET_ID}...`);
      await storage.createBucket(
        BUCKET_ID,
        "Item Images",
        [
          Permission.read(Role.any()),
          Permission.create(Role.users()),
          Permission.update(Role.users()),
          Permission.delete(Role.users()),
        ],
        true,
        true,
        10 * 1024 * 1024, // maximumFileSize
        ["jpg", "jpeg", "png", "webp"], // allowedFileExtensions
      );
      log(`Bucket created.`);
    }

    success = true;
    log("SETUP COMPLETE SUCCESSFULLY!");
  } catch (e: any) {
    log(`FATAL ERROR: ${e.message}`);
    console.error(e);
    success = false;
  }
}
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Database Setup</title>
    <style>
      body {
        font-family: monospace;
        background: #1a1a1a;
        color: #00ff00;
        padding: 2rem;
      }
      .log-entry {
        margin-bottom: 0.5rem;
        border-bottom: 1px solid #333;
        padding-bottom: 0.2rem;
      }
      .success {
        color: #00ff00;
        font-weight: bold;
        font-size: 1.2rem;
      }
      .error {
        color: #ff3333;
        font-weight: bold;
      }
      .btn {
        display: inline-block;
        padding: 10px 20px;
        background: #0077ff;
        color: white;
        text-decoration: none;
        border-radius: 5px;
        margin-top: 20px;
      }
    </style>
  </head>
  <body>
    <h1>Appwrite Database Setup</h1>

    <div id="logs">
      {
        logs.map((entry) => (
          <div class={`log-entry ${entry.includes("ERROR") ? "error" : ""}`}>
            {entry}
          </div>
        ))
      }
    </div>

    {
      success ? (
        <div class="success">
          <p>✅ Database Schema Repaired.</p>
          <p>
            Please wait 10 seconds for Appwrite to finish indexing, then try
            your app.
          </p>
          <a href="/dashboard" class="btn">
            Go to Dashboard
          </a>
        </div>
      ) : (
        <div class="error">
          <p>❌ Setup Failed. Check logs above.</p>
          <p>Ensure `APPWRITE_API_KEY` is in your `.env` file.</p>
        </div>
      )
    }
  </body>
</html>
