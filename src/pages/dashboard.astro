---
import Layout from '../layouts/Layout.astro';
import DashboardMetrics from '../components/dashboard/DashboardMetrics.vue';
---

<Layout title="Dashboard - Resale Command">
  <div class="container mx-auto p-4 space-y-8">
    
    <!-- Welcome Header -->
    <div class="flex justify-between items-center">
      <div>
        <h1 class="text-3xl font-bold">Command Center</h1>
        <p class="text-gray-500">Overview of your resale business</p>
      </div>
      <a href="/scout" class="btn btn-primary gap-2">
         🚀 Start Scouting
      </a>
    </div>

    <!-- Metrics & Data -->
    <DashboardMetrics client:load />

  </div>
</Layout>
