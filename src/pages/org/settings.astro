---
import Layout from '../../layouts/Layout.astro';
import OrgSettingsView from '../../components/org/OrgSettingsView.vue';
---

<Layout title="Organization Settings - Resale Command">
  <div class="container mx-auto p-4 max-w-4xl space-y-8">
    
    <div class="flex flex-col gap-2">
      <h1 class="text-3xl font-bold">Organization Settings</h1>
      <p class="text-gray-500">Manage your team and workspace.</p>
    </div>

    <!-- Client-side Org Management -->
    <OrgSettingsView client:load />

  </div>
</Layout>
