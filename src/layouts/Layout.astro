---
import Navbar from "@components/nav/Navbar.vue";
import TrackerDrawer from "@components/cart/TrackerDrawer.vue";
import Footer from "@components/Footer.astro";
import ToastContainer from "@components/ui/ToastContainer.vue";
import ConfirmContainer from "@components/ui/ConfirmContainer.vue";
import MarkdownModal from "@components/ui/MarkdownModal.astro";
import { siteConfig } from "site-config";

import "../styles/global.css";
import SEOmeta from "@components/SEOmeta.astro";

export interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const { title = siteConfig.title, description, image } = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="emerald">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="generator" content={Astro.generator} />

    <SEOmeta title={title} description={description} image={image} />
  </head>
</html>
<body>
  <div id="app-drawer" class="drawer drawer-end">
    <input id="tracker-drawer" type="checkbox" class="drawer-toggle" />
    
    <div class="drawer-content flex flex-col min-h-screen">
      <Navbar client:load />
      <main class="flex-1">
        <slot />
      </main>
      <Footer />
    </div>

    <div class="drawer-side z-[200]">
      <label for="tracker-drawer" aria-label="close sidebar" class="drawer-overlay"></label>
      <aside class="w-[100vw] sm:w-[400px] h-[100dvh] flex flex-col bg-base-200 shadow-xl overflow-hidden">
        <TrackerDrawer client:only="vue" />
      </aside>
    </div>
  </div>

  <MarkdownModal />
  <ToastContainer client:load />
  <ConfirmContainer client:load />
  <script>
    import { initAuth } from "../lib/store";

    // Initialize auth state on client load
    initAuth();
  </script>
</body>
